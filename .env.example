# Kustomer API key — role required: org.permission.kb.read
KUSTOMER_API_KEY=

# Your Kustomer org subdomain (e.g. "flexcar" for flexcar.kustomer.com)
KUSTOMER_ORG_SUBDOMAIN=

# Comma-separated list of allowed frontend origins (no wildcard)
# e.g. https://support.flexcar.com,http://localhost:5173
ALLOWED_ORIGIN=

# Port the server listens on (Railway injects $PORT automatically)
PORT=3000
